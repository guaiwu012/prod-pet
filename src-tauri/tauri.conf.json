{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PushPet",
  "version": "0.1.0",
  "identifier": "com.pushpet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "PushPet / 需求小兽",
        "width": 1180,
        "height": 780,
        "minWidth": 800,
        "minHeight": 620,
        "resizable": true
      },
      {
        "label": "pet",
        "url": "index.html?window=pet",
        "title": "需求小兽",
        "width": 90,
        "height": 110,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": true,
        "focusable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
